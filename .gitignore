# Git ignore rules for generated files and local workspace state

# Build outputs
*.o
*.a
*.so
*.dylib
*.exe

# Generated flow artifacts
artifacts/
backend/result/
synthesis/results/
temp/
synthesis/synth_actual.ys

# Layout files
*.gds
*.gdsii

# KiCad backups
kicad/**/*~
kicad/**/*-backups/
kicad/**/*.kicad_pcb-bak
kicad/**/*.kicad_sch-bak

# Logs
*.log
*.log.*

# Temp files
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.env

# Test outputs
tests/simulation/results/
tests/formal/results/
tests/simulation/*.vvp
tests/simulation/*.vcd

# Local working notes
PROGRESS.md
plan.md
