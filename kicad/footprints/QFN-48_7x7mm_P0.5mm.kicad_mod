(module QFN-48_7x7mm_P0.5mm (layer F.Cu) (tedit 63C00000)
  (descr "QFN-48 package, 7x7mm body, 0.5mm pitch, 48 pins + exposed pad")
  (tags "QFN QFN-48 7x7mm 0.5mm pitch")
  (attr smd)
  (fp_text reference REF** (at 0 -5.5) (layer F.SilkS)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value QFN-48_7x7mm_P0.5mm (at 0 5.5) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )

  ;; Courtyard
  (fp_line (start -4.85 -4.85) (end 4.85 -4.85) (layer F.CrtYd) (width 0.05))
  (fp_line (start 4.85 -4.85) (end 4.85 4.85) (layer F.CrtYd) (width 0.05))
  (fp_line (start 4.85 4.85) (end -4.85 4.85) (layer F.CrtYd) (width 0.05))
  (fp_line (start -4.85 4.85) (end -4.85 -4.85) (layer F.CrtYd) (width 0.05))

  ;; Fab layer outline (7x7mm body)
  (fp_line (start -3.5 -3.5) (end 3.5 -3.5) (layer F.Fab) (width 0.1))
  (fp_line (start 3.5 -3.5) (end 3.5 3.5) (layer F.Fab) (width 0.1))
  (fp_line (start 3.5 3.5) (end -3.5 3.5) (layer F.Fab) (width 0.1))
  (fp_line (start -3.5 3.5) (end -3.5 -3.5) (layer F.Fab) (width 0.1))

  ;; Silkscreen outline with pin 1 marker
  (fp_line (start -3.8 -3.8) (end 3.8 -3.8) (layer F.SilkS) (width 0.12))
  (fp_line (start 3.8 -3.8) (end 3.8 3.8) (layer F.SilkS) (width 0.12))
  (fp_line (start 3.8 3.8) (end -3.8 3.8) (layer F.SilkS) (width 0.12))
  (fp_line (start -3.8 3.8) (end -3.8 -3.8) (layer F.SilkS) (width 0.12))
  ;; Pin 1 marker
  (fp_line (start -4.1 -2.75) (end -4.1 -3.8) (layer F.SilkS) (width 0.12))
  (fp_line (start -4.1 -3.8) (end -2.75 -3.8) (layer F.SilkS) (width 0.12))

  ;; Exposed pad (center thermal pad)
  (pad "0" smd rect (at 0 0) (size 5.6 5.6) (layers F.Cu F.Paste F.Mask))

  ;; Bottom side pads (pins 1-12)
  (pad "1" smd rect (at -2.75 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "2" smd rect (at -2.25 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "3" smd rect (at -1.75 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "4" smd rect (at -1.25 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "5" smd rect (at -0.75 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "6" smd rect (at -0.25 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "7" smd rect (at 0.25 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "8" smd rect (at 0.75 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "9" smd rect (at 1.25 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "10" smd rect (at 1.75 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "11" smd rect (at 2.25 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "12" smd rect (at 2.75 -3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))

  ;; Right side pads (pins 13-24)
  (pad "13" smd rect (at 3.85 -2.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "14" smd rect (at 3.85 -2.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "15" smd rect (at 3.85 -1.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "16" smd rect (at 3.85 -1.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "17" smd rect (at 3.85 -0.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "18" smd rect (at 3.85 -0.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "19" smd rect (at 3.85 0.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "20" smd rect (at 3.85 0.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "21" smd rect (at 3.85 1.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "22" smd rect (at 3.85 1.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "23" smd rect (at 3.85 2.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "24" smd rect (at 3.85 2.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))

  ;; Top side pads (pins 25-36)
  (pad "25" smd rect (at 2.75 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "26" smd rect (at 2.25 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "27" smd rect (at 1.75 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "28" smd rect (at 1.25 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "29" smd rect (at 0.75 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "30" smd rect (at 0.25 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "31" smd rect (at -0.25 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "32" smd rect (at -0.75 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "33" smd rect (at -1.25 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "34" smd rect (at -1.75 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "35" smd rect (at -2.25 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))
  (pad "36" smd rect (at -2.75 3.85) (size 0.3 0.8) (layers F.Cu F.Paste F.Mask))

  ;; Left side pads (pins 37-48)
  (pad "37" smd rect (at -3.85 2.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "38" smd rect (at -3.85 2.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "39" smd rect (at -3.85 1.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "40" smd rect (at -3.85 1.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "41" smd rect (at -3.85 0.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "42" smd rect (at -3.85 0.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "43" smd rect (at -3.85 -0.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "44" smd rect (at -3.85 -0.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "45" smd rect (at -3.85 -1.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "46" smd rect (at -3.85 -1.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "47" smd rect (at -3.85 -2.25) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
  (pad "48" smd rect (at -3.85 -2.75) (size 0.8 0.3) (layers F.Cu F.Paste F.Mask))
)
