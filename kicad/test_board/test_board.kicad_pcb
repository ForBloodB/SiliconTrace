(kicad_pcb (version 20221018) (generator kicad_pcb)

  (general
    (thickness 1.6)
  )

  (paper "A4")

  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal)
    (2 "In2.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fab")
    (49 "F.Fab" user "F.Fab")
  )

  (setup
    (pad_to_mask_clearance 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (disableapertmacros false)
      (usegerberextensions false)
      (usegerberattributes true)
      (usegerberadvancedattributes true)
      (creategerberjobfile true)
      (svguseinch false)
      (svgprecision 6)
      (excludeedgelayer true)
      (linewidth 0.100000)
      (plotframeref false)
      (viasonmask false)
      (mode 1)
      (useauxorigin false)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (dxfpolygonmode true)
      (dxfimperialunits true)
      (dxfusepcbnewfont true)
      (psnegative false)
      (psa4output false)
      (plotreference true)
      (plotvalue true)
      (plotinvisibletext false)
      (sketchpadsonfab false)
      (subtractmaskfromsilk false)
      (outputformat 1)
      (mirror false)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "")
    )
  )

  (net 0 "")
  (net 1 "VDD")
  (net 2 "VSS")
  (net 3 "clk")
  (net 4 "resetn")
  (net 5 "JTAG_TMS")
  (net 6 "JTAG_TCK")
  (net 7 "JTAG_TDI")
  (net 8 "JTAG_TDO")

  ;; Board outline - 40mm x 30mm
  (gr_rect (start 0 0) (end 40000 30000) (stroke (width 0.1) (type default)) (layer "Edge.Cuts") (tstamp 00000000-0000-0000-0000-000000000001))

  ;; Mounting holes at corners
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000010)
    (at 2000 2000)
    (pad "1" thru_hole circle (at 0 0) (size 2200 2200) (drill 2200) (layers "*.Cu" "*.Mask") (net 2 "VSS"))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000011)
    (at 38000 2000)
    (pad "1" thru_hole circle (at 0 0) (size 2200 2200) (drill 2200) (layers "*.Cu" "*.Mask") (net 2 "VSS"))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000012)
    (at 2000 28000)
    (pad "1" thru_hole circle (at 0 0) (size 2200 2200) (drill 2200) (layers "*.Cu" "*.Mask") (net 2 "VSS"))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000013)
    (at 38000 28000)
    (pad "1" thru_hole circle (at 0 0) (size 2200 2200) (drill 2200) (layers "*.Cu" "*.Mask") (net 2 "VSS"))
  )

  ;; QFN-48 chip at center
  (footprint "kicad:QFN-48_7x7mm_P0.5mm" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000020)
    (at 20000 15000)
    (pad "1" smd rect (at -3750 -3250) (size 300 1300) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "clk"))
    (pad "2" smd rect (at -3250 -3250) (size 300 1300) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "resetn"))
    (pad "3" smd rect (at -2750 -3250) (size 300 1300) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "JTAG_TMS"))
    (pad "4" smd rect (at -2250 -3250) (size 300 1300) (layers "F.Cu" "F.Paste" "F.Mask") (net 6 "JTAG_TCK"))
    (pad "5" smd rect (at -1750 -3250) (size 300 1300) (layers "F.Cu" "F.Paste" "F.Mask") (net 7 "JTAG_TDI"))
    (pad "6" smd rect (at -1250 -3250) (size 300 1300) (layers "F.Cu" "F.Paste" "F.Mask") (net 8 "JTAG_TDO"))
    (pad "49" smd rect (at 0 0) (size 5000 5000) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "VSS"))
  )

  ;; Decoupling capacitors (100nF)
  (footprint "Capacitor_SMD:C_0402_1005Metric" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000030)
    (at 25000 15000)
    (pad "1" smd rect (at -500 0) (size 500 600) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "VDD"))
    (pad "2" smd rect (at 500 0) (size 500 600) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "VSS"))
  )
  (footprint "Capacitor_SMD:C_0402_1005Metric" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000031)
    (at 15000 15000)
    (pad "1" smd rect (at -500 0) (size 500 600) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "VDD"))
    (pad "2" smd rect (at 500 0) (size 500 600) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "VSS"))
  )

  ;; JTAG header (2x5 pin header)
  (footprint "Connector_PinHeader_2.54mm:PinHeader_2x05_P2.54mm_Vertical" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000040)
    (at 5000 15000)
    (pad "1" thru_hole rect (at -3810 -1270) (size 1700 1700) (drill 1000) (layers "*.Cu" "*.Mask") (net 5 "JTAG_TMS"))
    (pad "2" thru_hole oval (at -1270 -1270) (size 1700 1700) (drill 1000) (layers "*.Cu" "*.Mask") (net 6 "JTAG_TCK"))
    (pad "3" thru_hole oval (at 1270 -1270) (size 1700 1700) (drill 1000) (layers "*.Cu" "*.Mask") (net 7 "JTAG_TDI"))
    (pad "4" thru_hole oval (at 3810 -1270) (size 1700 1700) (drill 1000) (layers "*.Cu" "*.Mask") (net 8 "JTAG_TDO"))
    (pad "5" thru_hole oval (at -3810 1270) (size 1700 1700) (drill 1000) (layers "*.Cu" "*.Mask") (net 1 "VDD"))
    (pad "6" thru_hole oval (at -1270 1270) (size 1700 1700) (drill 1000) (layers "*.Cu" "*.Mask") (net 2 "VSS"))
  )

  ;; Crystal oscillator (100MHz)
  (footprint "Crystal:Crystal_SMD_3215-2Pin_3.2x1.5mm" (layer "F.Cu")
    (tstamp 00000000-0000-0000-0000-000000000050)
    (at 20000 10000)
    (pad "1" smd rect (at -1100 0) (size 1000 900) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "clk"))
    (pad "2" smd rect (at 1100 0) (size 1000 900) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "VSS"))
  )

  ;; Ground plane on In1.Cu
  (zone (net 2) (net_name "VSS") (layer "In1.Cu") (tstamp 00000000-0000-0000-0000-000000000060)
    (hatch edge 0.508)
    (connect_pads (clearance 0.508))
    (min_thickness 0.254)
    (fill yes (thermal_gap 0.508) (thermal_bridge_width 0.508))
    (polygon
      (pts (xy 0 0) (xy 40000 0) (xy 40000 30000) (xy 0 30000))
    )
  )

  ;; Power plane on In2.Cu
  (zone (net 1) (net_name "VDD") (layer "In2.Cu") (tstamp 00000000-0000-0000-0000-000000000061)
    (hatch edge 0.508)
    (connect_pads (clearance 0.508))
    (min_thickness 0.254)
    (fill yes (thermal_gap 0.508) (thermal_bridge_width 0.508))
    (polygon
      (pts (xy 0 0) (xy 40000 0) (xy 40000 30000) (xy 0 30000))
    )
  )

)
