# Backend defaults for the PicoRV32 regression.
: "${CORE_MARGIN_UM:=20}"
: "${MIN_CORE_SIDE_UM:=1500}"
: "${BOTTOM_ROUTING_LAYER:=met1}"
: "${TOP_ROUTING_LAYER:=met5}"
: "${RT_FULL_PA_ITER:=0}"
: "${RT_FULL_DR_ITER:=0}"
: "${RT_DR_REPEAT:=5}"
: "${ROUTE_INPUT_STAGE:=hold}"
: "${PL_TARGET_DENSITY:=0.10}"
: "${PDN_ENABLE_STRIPES:=0}"
